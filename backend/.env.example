# Server
PORT=3000
BACKEND_BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:5173

LLAMA_CPP_URL=http://localhost:8080/v1
SUPPRESS_CONSOLE=false

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database
DATABASE_PATH=backend/data/database.sqlite

# Security
SESSION_SECRET=<generate-a-secure-random-string>
SESSION_EXPIRY_HOURS=24

# Multi-domain support (optional)
# Comma-separated list of allowed hostnames for CORS and URL validation
# Leave empty to allow any domain (useful for dev)
# Examples:
#   ALLOWED_DOMAINS=localhost:5173,localhost:3000
#   ALLOWED_DOMAINS=192.168.1.100:80,mygateway.ts.net:80
ALLOWED_DOMAINS=

